{
  "name": "mnemomark-pwa",
  "version": "1.0.0",
  "description": "MnemoMark Progressive Web App",
  "scripts": {
    "build": "node build.js",
    "pwa:package": "npx @pwabuilder/pwabuilder --url https://david123ojikutu.github.io/MnemoMark/ --platform windows --platform android --out ./pwa/packages",
    "pwa:package-tag-relations": "npx @pwabuilder/pwabuilder --url https://david123ojikutu.github.io/MnemoMark/tag-relations-pwa/ --platform windows --platform android --out ./pwa/packages-tag-relations",
    "firebase:login": "npx firebase-tools login",
    "firebase:serve": "npx firebase-tools emulators:start --only hosting",
    "firebase:deploy": "npx firebase-tools deploy --only hosting"
  },
  "author": {
    "name": "MnemoMark",
    "email": "david123ojikutu@users.noreply.github.com"
  },
  "homepage": "https://github.com/david123ojikutu/MnemoMark",
  "license": "MIT"
}
